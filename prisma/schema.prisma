generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =======================
// AUTH & USERS MODULE
// =======================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  isActive     Boolean  @default(true)
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  projectsManaged Project[]  @relation("ProjectManager")
  auditLogs       AuditLog[]
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // e.g., Admin, PM, Accountant, Executive
  description String?
  permissions Permission[] @relation("RolePermissions") // Many-to-Many
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String  @id @default(uuid())
  name        String  @unique // e.g., "CREATE_PROJECT", "APPROVE_INVOICE"
  description String?
  roles       Role[]  @relation("RolePermissions") // Many-to-Many
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String // e.g., "CERTIFIED_INVOICE"
  entity    String // e.g., "Invoice"
  entityId  String
  details   Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// =======================
// PROJECTS & WBS MODULE
// =======================

model Client {
  id              String  @id @default(uuid())
  name            String  @unique
  commercialName  String?
  contactPerson   String?
  phone           String?
  email           String?
  taxNumber       String?
  crNumber        String? // نوع السجل
  address         String?
  activityType    String?
  notes           String?

  projects      Project[]
  quotations    Quotation[]
  
  // Daftra Integration (Mapped as Client)
  daftraClientId String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Project {
  id          String        @id @default(uuid())
  name        String
  code        String        @unique
  description String?
  status      String        @default("PLANNING")
  startDate   DateTime?
  endDate     DateTime?
  managerId   String?
  manager     User?         @relation("ProjectManager", fields: [managerId], references: [id])

  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id])

  // Budget & Financials
  targetRevenue      Float @default(0)
  estimatedBudget    Float @default(0)

  warehouses  Warehouse[]

  // Daftra Integration Mappings
  daftraCustomerId   String?
  daftraCostCenterId String?

  // Relations
  boqItems       BOQItem[]
  activities     Activity[]
  contracts      Contract[]
  invoices       Invoice[]
  purchaseOrders PurchaseOrder[] // New Relation for Procurement
  quotation      Quotation?
  expenses       Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BOQItem {
  id          String  @id @default(uuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  itemCode    String
  description String
  unit        String
  quantity    Float
  unitPrice   Float // Client Price (Selling price)
  totalValue  Float // quantity * unitPrice (Client Total)

  // Execution Strategy
  executionType       String @default("SELF") // 'SELF' or 'SUBCONTRACT'
  subcontractorPrice  Float? // Cost Price (if subcontracted)

  estimatedUnitCost   Float @default(0) // التكلفة التقديرية للوحدة
  estimatedTotalCost  Float @default(0)

  // Tracking Progress
  executedQty Float @default(0)

  // Relations
  activityLinks  ActivityBOQLink[]
  invoiceDetails InvoiceDetail[]
  purchaseItems  PurchaseOrderItem[] // Track material purchases against this task
  contractItems  ContractItem[] // Link to sub-scopes assigned to subcontractors
  changeOrderItems ChangeOrderItem[] // Track additions/deductions
  materialTransactions MaterialTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id        String     @id @default(uuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Activity?  @relation("WBSHierarchy", fields: [parentId], references: [id])
  children  Activity[] @relation("WBSHierarchy")

  name              String
  startDate         DateTime?
  endDate           DateTime?
  completionPercent Float     @default(0)

  boqLinks ActivityBOQLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityBOQLink {
  id          String   @id @default(uuid())
  activityId  String
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  boqItemId   String
  boqItem     BOQItem  @relation(fields: [boqItemId], references: [id], onDelete: Cascade)
  assignedQty Float
}

// =======================
// CONTRACTS & SUBCONTRACTORS
// =======================

// Redundant Subcontractor model removed. Using Supplier instead for all vendors/subcontractors.


model Contract {
  id        String       @id @default(uuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String       @default("MAIN_CONTRACT") // Main or Subcontractor

  subcontractorId String?
  subcontractor   Supplier? @relation(fields: [subcontractorId], references: [id])

  referenceNumber  String @unique
  totalValue       Float
  retentionPercent Float  @default(0) // percentage deductions
  advancePayment   Float  @default(0)

  invoices Invoice[]
  items    ContractItem[] // Specific items assigned to this contract from the project BOQ
  changeOrders ChangeOrder[] // ملاحق العقود والأوامر التغييرية

  createdBy   String?
  approvedBy  String?
  approvedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChangeOrder {
  id              String   @id @default(uuid())
  contractId      String
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  orderNumber     String   @unique
  title           String
  type            String   @default("ADDITION") // ADDITION | DEDUCTION
  status          String   @default("DRAFT") // DRAFT, APPROVED
  
  issueDate       DateTime @default(now())
  approvedDate    DateTime?
  
  amount          Float    // Total value of the addendum
  
  createdBy       String?
  approvedBy      String?
  
  items           ChangeOrderItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ChangeOrderItem {
  id              String      @id @default(uuid())
  changeOrderId   String
  changeOrder     ChangeOrder @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)
  
  boqItemId       String?     // Link to existing or new BOQ item
  boqItem         BOQItem?    @relation(fields: [boqItemId], references: [id])
  
  description     String
  quantityChange  Float       // Positive or negative
  unitPrice       Float
  totalValue      Float       // quantityChange * unitPrice

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ContractItem {
  id         String   @id @default(uuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  boqItemId  String
  boqItem    BOQItem  @relation(fields: [boqItemId], references: [id])

  assignedQty Float    // The portion of the project quantity assigned to this contractor
  unitPrice   Float    // This subcontractor's rate for this item
  totalValue  Float    // assignedQty * unitPrice

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// INVOICING (Mustaqlasat)
// =======================

model Invoice {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])

  invoiceNumber   String
  issueDate       DateTime
  periodStartDate DateTime?
  periodEndDate   DateTime?

  // Finance Totals
  grossAmount      Float
  
  // Tax
  taxPercent       Float @default(0)
  taxAmount        Float @default(0)
  
  // Deductions
  retentionPercent Float @default(0)
  retentionAmount  Float @default(0)
  advanceDeduction Float @default(0)
  delayPenalty     Float @default(0) // غرامة تأخير
  otherDeductions  Float @default(0) // خصومات أخرى
  
  // Deduction Controls
  deductionTiming  String  @default("AFTER_VAT") // "BEFORE_VAT" | "AFTER_VAT"
  deferDeductions  Boolean @default(false)        // إذا true: لا يُرسل الخصومات لدفترة ويؤجلها للمستخلص القادم
  netAmount        Float
  
  status          String @default("DRAFT")
  daftraInvoiceId String? // Integration

  paymentStatus   String @default("UNPAID") // UNPAID, PARTIAL, PAID
  paidAmount      Float @default(0)

  createdBy       String?
  approvedBy      String?
  approvedAt      DateTime?

  details InvoiceDetail[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvoiceDetail {
  id        String  @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  boqItemId String
  boqItem     BOQItem @relation(fields: [boqItemId], references: [id])

  previousQty Float @default(0)
  currentQty  Float @default(0) // New execution this period
  totalQty    Float // previousQty + currentQty

  unitPrice    Float // Price when invoice was generated
  currentValue Float // Executed value this period
}

// =======================
// PROCUREMENT & MATERIALS
// =======================

model Supplier {
  id             String  @id @default(uuid())
  name           String
  commercialName String?
  contactPerson  String?
  phone          String?
  email          String?
  taxNumber      String?
  crNumber       String?
  address        String?
  activityType   String?
  notes          String?
  
  // Daftra Integration (Mapped as Vendor/Supplier)
  daftraSupplierId String?
  
  contracts      Contract[]
  purchaseOrders PurchaseOrder[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Material {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  unit        String   // e.g. Ton, M3, KG, LS (Lump Sum for Services)
  type        String   @default("MATERIAL") // MATERIAL, SERVICE, EQUIPMENT
  defaultPrice Float?

  poItems     PurchaseOrderItem[]
  stocks      InventoryStock[]
  transactions MaterialTransaction[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PurchaseOrder {
  id            String   @id @default(uuid())
  poNumber      String   @unique
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  
  status        String   @default("PENDING") // PENDING, APPROVED, DELIVERED, CANCELLED
  issueDate     DateTime @default(now())
  expectedDate  DateTime?
  
  totalAmount   Float    @default(0)
  taxAmount     Float    @default(0)
  netAmount     Float    @default(0) // totalAmount + taxAmount

  paymentStatus String   @default("UNPAID") // UNPAID, PARTIAL, PAID
  paidAmount    Float    @default(0)
  daftraId      String?  // Sync ID from Daftra

  createdBy     String?
  approvedBy    String?
  approvedAt    DateTime?

  items         PurchaseOrderItem[]
  materialTransactions MaterialTransaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PurchaseOrderItem {
  id              String         @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  materialId      String
  material        Material       @relation(fields: [materialId], references: [id])
  
  quantity        Float
  unitPrice       Float
  totalPrice      Float          // quantity * unitPrice
  
  // Link to a specific BOQ Item to track material cost strictly against a task
  boqItemId       String?
  boqItem         BOQItem?       @relation(fields: [boqItemId], references: [id])
}

// =======================
// QUOTATIONS (Proposals)
// =======================

model Quotation {
  id              String   @id @default(uuid())
  quotationNumber String   @unique
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  
  title           String
  status          String   @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED
  
  technicalOffer  String?
  termsConditions String?
  
  totalAmount     Float    @default(0)
  hasVat          Boolean  @default(false)
  vatAmount       Float    @default(0)
  netAmount       Float    @default(0)
  
  createdBy       String?
  approvedBy      String?
  approvedAt      DateTime?

  items           QuotationItem[]
  
  // Backlink to project if it's converted
  projectId       String?  @unique
  project         Project? @relation(fields: [projectId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  
  itemCode    String
  description String
  unit        String
  quantity    Float
  unitPrice   Float     // Client Price (Selling price)
  totalValue  Float     // quantity * unitPrice
  estimatedUnitCost   Float @default(0) // Estimated Cost
}

// =======================
// SYSTEM SETTINGS
// =======================

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique // e.g. "DAFTRA_DOMAIN", "DAFTRA_API_KEY"
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// EXPENSES & PETTY CASH
// =======================

model Expense {
  id          String   @id @default(uuid())
  expenseNo   String   @unique // e.g. EXP-2026-001
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  
  description String
  category    String   // FUEL, FOOD, LOGISTICS, SITE_MATERIALS, OTHER
  amount      Float
  
  date        DateTime @default(now())
  status      String   @default("APPROVED") // PENDING, APPROVED, REJECTED
  
  requestedBy String?  
  isPettyCash Boolean  @default(true) 
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// =======================
// SYSTEM & COMPANY CONFIG
// =======================

model CompanyProfile {
  id              String   @id @default("1")
  nameAr          String   @default("المقاول الغامض")
  nameEn          String?  
  logoUrl         String?
  stampUrl        String?
  taxNumber       String? // الرقم الضريبي
  crNumber        String? // السجل التجاري
  address         String?
  phone           String?
  email           String?
  website         String?
  managerName     String?
  updatedAt       DateTime @updatedAt
}

// =======================
// INVENTORY & WAREHOUSING
// =======================

model Warehouse {
  id          String   @id @default(uuid())
  name        String
  location    String?
  projectId   String?  
  project     Project? @relation(fields: [projectId], references: [id])
  
  stocks      InventoryStock[]
  transactions MaterialTransaction[]
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryStock {
  id          String   @id @default(uuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  materialId  String
  material    Material  @relation(fields: [materialId], references: [id])
  
  quantity    Float    @default(0)
  
  updatedAt   DateTime @updatedAt

  @@unique([warehouseId, materialId])
}

model MaterialTransaction {
  id            String   @id @default(uuid())
  referenceNo   String   @unique // GRN-001, MIS-002
  type          String   // RECEIPT, ISSUE, TRANSFER, ADJUSTMENT
  date          DateTime @default(now())
  
  warehouseId   String
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  
  materialId    String
  material      Material  @relation(fields: [materialId], references: [id])
  
  quantity      Float    
  
  poId          String?  
  po            PurchaseOrder? @relation(fields: [poId], references: [id])
  
  boqItemId     String?  
  boqItem       BOQItem? @relation(fields: [boqItemId], references: [id])
  
  remarks       String?
  createdBy     String?  // User acting
  createdAt     DateTime @default(now())
}

